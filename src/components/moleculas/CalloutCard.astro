---
interface Props {
  title?: string;
  variant?: "info" | "tip" | "default";
  class?: string;
}
const { title, variant = "default", class: className = "" } = Astro.props;
const variants = {
  info: "border-sky-200 dark:border-sky-800/60 bg-sky-50/80 dark:bg-sky-950/40",
  tip: "border-emerald-200 dark:border-emerald-800/60 bg-emerald-50/80 dark:bg-emerald-950/40",
  default: "border-slate-200 dark:border-slate-700/60 bg-slate-50 dark:bg-slate-900/30",
};
---
<aside
  class:list={[
    "rounded-xl border p-4 sm:p-5",
    variants[variant],
    className
  ]}
  role="note"
>
  {title && (
    <p class="text-sm font-semibold uppercase tracking-wider text-slate-500 dark:text-slate-400 mb-2">
      {title}
    </p>
  )}
  <div class="text-[15px] text-slate-700 dark:text-slate-300 leading-relaxed [&_a]:font-medium [&_a]:text-sky-600 [&_a:hover]:underline dark:[&_a]:text-sky-400">
    <slot />
  </div>
</aside>
